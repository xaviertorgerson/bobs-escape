  var take=""; if(m.take&&m.take.length){
    take='<div class="takeaways">'+m.take.map(function(t,i){return '<div class="takeaway"><span class="tk">'+(i+1)+'</span><span>'+t+'</span></div>';}).join("")+'</div>';
  }
  head.innerHTML=crumb+'<h2>'+m.title+'</h2><p class="bigidea">'+m.blurb+'</p>'+take;
