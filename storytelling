/* ---------------- framework explorer ---------------- */
(function buildExplorer(){
  var tabs=document.getElementById("fwTabs");
  FRAMEWORKS.forEach(function(f,i){
    var t=document.createElement("button"); t.className="tab"+(i===0?" active":""); t.textContent=f.name; t.dataset.fw=f.id;
    tabs.appendChild(t);
  });
  renderFw(FRAMEWORKS[0]);
  tabs.addEventListener("click",function(e){
    var t=e.target.closest(".tab"); if(!t) return;
    tabs.querySelectorAll(".tab").forEach(function(x){x.classList.remove("active");});
    t.classList.add("active");
    renderFw(FRAMEWORKS.filter(function(f){return f.id===t.dataset.fw;})[0]);
  });
  // matcher
  var mEl=document.getElementById("matcher");
  MATCH.forEach(function(r){
    var row=document.createElement("div"); row.className="mrow"; row.dataset.fw=r[2];
    row.innerHTML='<span class="goal">'+r[0]+'</span><span class="fw">'+r[1]+'</span><span class="go">↗</span>';
    mEl.appendChild(row);
  });
  mEl.addEventListener("click",function(e){
    var row=e.target.closest(".mrow"); if(!row) return;
    var id=row.dataset.fw;
    tabs.querySelectorAll(".tab").forEach(function(x){x.classList.toggle("active",x.dataset.fw===id);});
    renderFw(FRAMEWORKS.filter(function(f){return f.id===id;})[0]);
    document.getElementById("fwExplorer").scrollIntoView({behavior:"smooth",block:"center"});
  });
  function renderFw(f){
    var strip=f.beats.map(function(b,i){return '<span class="beat"><span class="bi">'+(i+1)+'</span>'+b+'</span>';}).join("");
    document.getElementById("fwExplorer").innerHTML=
      '<div class="ex-top"><h4>'+f.name+'</h4><span class="best">best for: '+f.best+'</span></div>'+
      '<p class="ex-desc">'+f.desc+'</p><div class="beatstrip">'+strip+'</div>';
  }
})();

/* ---------------- story curve interaction ---------------- */
(function buildArc(){
  var svg=document.getElementById("arcsvg"); if(!svg) return;
  var ns="http://www.w3.org/2000/svg";
  var read=document.getElementById("arcReadout");
  function show(b,el){
    svg.querySelectorAll(".beatdot").forEach(function(d){d.classList.remove("sel");});
    if(el) el.classList.add("sel");
    read.innerHTML='<div class="rn">●</div><div><h4>'+b.t+'</h4><p>'+b.d+'</p></div>';
  }
  ARC.forEach(function(b,i){
    var c=document.createElementNS(ns,"circle");
    c.setAttribute("class","beatdot"); c.setAttribute("cx",b.x); c.setAttribute("cy",b.y); c.setAttribute("r","6.5");
    c.setAttribute("tabindex","0"); c.setAttribute("role","button"); c.setAttribute("aria-label",b.t);
    c.addEventListener("mouseenter",function(){show(b,c);});
    c.addEventListener("click",function(){show(b,c);});
    c.addEventListener("focus",function(){show(b,c);});
    svg.appendChild(c);
    var lab=document.createElementNS(ns,"text");
    lab.setAttribute("class","beatlbl");
    lab.setAttribute("x",b.x); lab.setAttribute("y", b.y<160 ? b.y-14 : b.y+22);
    lab.setAttribute("text-anchor", b.x<80?"start":(b.x>760?"end":"middle"));
    lab.textContent=b.t; svg.appendChild(lab);
  });
})();

/* ---------------- router ---------------- */
var main=document.getElementById("main");
var sidebar=document.getElementById("sidebar"); var overlay=document.getElementById("overlay");
function isMobile(){return window.innerWidth<=860;}
function closeDrawer(){sidebar.classList.remove("open");overlay.classList.remove("show");}

function setActive(id){
  Object.keys(navLinks).forEach(function(k){navLinks[k].classList.toggle("active",k===id);});
}
function show(id,anchor){
  if(!document.getElementById(id)) id="home";
  document.querySelectorAll(".module").forEach(function(m){m.classList.toggle("active",m.id===id);});
  setActive(id);
  // scroll
  if(anchor){
    var a=document.getElementById(anchor);
    setTimeout(function(){ if(a) a.scrollIntoView({behavior:"smooth",block:"start"}); else window.scrollTo(0,0); },60);
  } else { window.scrollTo({top:0,behavior:"auto"}); }
  buildPrevNext(id);
  refreshChecks();
  if(isMobile()) closeDrawer();
}
function go(id,anchor){
  var hash = anchor ? (id+"::"+anchor) : id;
  if(location.hash.slice(1)===hash){ show(id,anchor); } else { location.hash=hash; }
}
window.addEventListener("hashchange",function(){route();});
function route(){
  var h=decodeURIComponent(location.hash.slice(1));
  if(!h){ show("home"); return; }
  var parts=h.split("::"); show(parts[0],parts[1]);
}

/* delegate all [data-go] clicks */
document.addEventListener("click",function(e){
  var el=e.target.closest("[data-go]"); if(!el) return;
  e.preventDefault();
  go(el.dataset.go, el.dataset.anchor||null);
});

/* ---------------- prev / next ---------------- */
function buildPrevNext(id){
  var sec=document.getElementById(id); if(!sec) return;
  var inner=sec.querySelector(".inner"); if(!inner) return;
  var old=inner.querySelector(".prevnext"); if(old) old.remove();
  var oldC=inner.querySelector(".complete"); if(oldC) oldC.remove();
  if(id==="home") return;

  // complete toggle (lessons only)
  if(LESSONS.indexOf(id)!==-1){
    var c=document.createElement("div"); c.className="complete";
    var done=!!DONE[id];
    c.innerHTML='<button class="btn'+(done?" done":"")+'" id="cbtn">'+(done?"✓ Completed":"Mark this lesson complete")+'</button>';
    inner.appendChild(c);
    c.querySelector("#cbtn").addEventListener("click",function(){
      DONE[id]=!DONE[id]; saveDone(); refreshChecks();
      var b=c.querySelector("#cbtn");
      b.classList.toggle("done",!!DONE[id]);
      b.textContent=DONE[id]?"✓ Completed":"Mark this lesson complete";
    });
  }

  var idx=ORDER.indexOf(id);
  var prev=idx>0?ORDER[idx-1]:null, next=idx<ORDER.length-1?ORDER[idx+1]:null;
  function meta(mid){ if(mid==="home") return {t:"Course Map"}; var m=MODS.filter(function(x){return x.id===mid;})[0]; return {t:m?m.title:""}; }
  var pn=document.createElement("div"); pn.className="prevnext";
  var prevHTML = prev?'<a class="pn" data-go="'+prev+'"><span class="d">← Previous</span><div class="tt">'+meta(prev).t+'</div></a>':'<span></span>';
  var nextHTML = next?'<a class="pn next" data-go="'+next+'"><span class="d">Next →</span><div class="tt">'+meta(next).t+'</div></a>'
                     :'<a class="pn next" data-go="home"><span class="d">Course complete ↺</span><div class="tt">Back to the map</div></a>';
  pn.innerHTML=prevHTML+nextHTML;
  inner.appendChild(pn);
}

/* ---------------- progress ring + checks ---------------- */
var ringfg=document.getElementById("ringfg"), ringtxt=document.getElementById("ringtxt");
function refreshChecks(){
  var done=0;
  LESSONS.forEach(function(id){ if(DONE[id]){done++; if(navLinks[id])navLinks[id].classList.add("done");} else if(navLinks[id]) navLinks[id].classList.remove("done"); });
  var pct=done/LESSONS.length;
  var circ=2*Math.PI*14;
  ringfg.setAttribute("stroke-dasharray",circ.toFixed(1));
  ringfg.setAttribute("stroke-dashoffset",(circ*(1-pct)).toFixed(1));
  ringtxt.innerHTML=done+" of "+LESSONS.length+" lessons<br>complete";
}

/* ---------------- chrome: scrollbar, toTop, drawer, search, keys ---------------- */
var bar=document.getElementById("scrollbar"), toTop=document.getElementById("toTop");
window.addEventListener("scroll",function(){
  var h=document.documentElement,s=h.scrollTop,max=h.scrollHeight-h.clientHeight;
  bar.style.width=(max>0?(s/max)*100:0)+"%";
  toTop.classList.toggle("show",s>500);
},{passive:true});
toTop.addEventListener("click",function(){window.scrollTo({top:0,behavior:"smooth"});});

document.getElementById("menuBtn").addEventListener("click",function(){
  sidebar.classList.toggle("open"); overlay.classList.toggle("show",sidebar.classList.contains("open"));
});
overlay.addEventListener("click",closeDrawer);

var search=document.getElementById("search");
search.addEventListener("input",function(){
  var q=search.value.trim().toLowerCase();
  // search lesson titles + takeaways + sub labels
  Object.keys(navLinks).forEach(function(id){
    var link=navLinks[id]; if(id==="home"){link.style.display="";return;}
    var m=MODS.filter(function(x){return x.id===id;})[0]; if(!m){link.style.display="";return;}
    var hay=(m.title+" "+(m.take||[]).join(" ")+" "+(m.subs||[]).map(function(s){return s[1];}).join(" ")).toLowerCase();
    var match=!q||hay.indexOf(q)!==-1;
    link.style.display=match?"":"none";
    var sn=link.nextElementSibling;
    if(sn&&sn.classList.contains("subnav")) sn.style.display=match&&link.classList.contains("active")?"":(match?"":"none");
  });
  // hide empty phase headers
  nav.querySelectorAll(".phase").forEach(function(ph){
    var el=ph.nextElementSibling, any=false;
    while(el&&!el.classList.contains("phase")){ if(el.classList.contains("navlink")&&el.style.display!=="none") any=true; el=el.nextElementSibling; }
    ph.style.display=any?"":"none";
  });
});

document.addEventListener("keydown",function(e){
  if(e.target.tagName==="INPUT"||e.target.tagName==="TEXTAREA"||e.target.isContentEditable) return;
  var cur=location.hash.slice(1).split("::")[0]||"home";
  var idx=ORDER.indexOf(cur);
  if(e.key==="ArrowRight"&&idx<ORDER.length-1) go(ORDER[idx+1]);
  if(e.key==="ArrowLeft"&&idx>0) go(ORDER[idx-1]);
});

