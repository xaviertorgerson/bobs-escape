  body{font-size:17px;}
  #topbar{display:flex;} #overlay.show{display:block;}
  #sidebar{position:fixed;top:0;left:0;transform:translateX(-100%);transition:transform .3s cubic-bezier(.4,0,.2,1);
    width:330px;max-width:88vw;box-shadow:0 0 60px rgba(27,24,19,.3);}
  #sidebar.open{transform:translateX(0);}
  .inner{padding:74px 22px 30px;}
  .cg-2,.cg-3,.engine,.vs,.prevnext,.resgrid{grid-template-columns:1fr;}
  .engine .arrow{transform:rotate(90deg);}
  .laws{grid-template-columns:1fr 1fr;} .map{grid-template-columns:1fr;}
  .node::after{content:"↓";right:auto;left:50%;top:auto;bottom:-12px;transform:translateX(-50%);}
  .pn.next{text-align:left;}
}
@media (max-width:520px){ .laws{grid-template-columns:1fr;} .vs{grid-template-columns:1fr;} .lenname{flex-basis:96px;} .lenname .ll{font-size:15px;} }
