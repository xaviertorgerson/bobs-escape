/* ---------------- storage (guarded) ---------------- */
function loadStore(key){ try{ return JSON.parse(localStorage.getItem(key)||"{}")||{}; }catch(e){ return {}; } }
function putStore(key,obj){ try{ localStorage.setItem(key,JSON.stringify(obj)); }catch(e){} }
var DONE={};
try{ DONE=JSON.parse(localStorage.getItem("aos_done")||"{}")||{}; }catch(e){ DONE={}; }
function saveDone(){ try{ localStorage.setItem("aos_done",JSON.stringify(DONE)); }catch(e){} }
var CHECKS=loadStore("aos_checks");
var WORK=loadStore("aos_work");

/* ---------------- build sidebar ---------------- */
var nav=document.getElementById("nav");
var navLinks={};
(function buildNav(){
  var homeBtn=document.createElement("button");
  homeBtn.className="navlink"; homeBtn.dataset.go="home";
  homeBtn.innerHTML='<span class="n">◊</span><span class="t">Course Map</span><span class="chk"></span>';
  nav.appendChild(homeBtn); navLinks["home"]=homeBtn;

  PHASES.forEach(function(ph,pi){
    var inThis=MODS.filter(function(m){return m.phase===pi;});
    if(!inThis.length) return;
    var ph_el=document.createElement("div"); ph_el.className="phase";
    ph_el.innerHTML='<span class="pd" style="background:'+ph.color+'"></span>'+ph.name;
    nav.appendChild(ph_el);
    inThis.forEach(function(m){
      var b=document.createElement("button"); b.className="navlink"; b.dataset.go=m.id;
      b.innerHTML='<span class="n">'+m.n+'</span><span class="t">'+m.title+'</span><span class="chk">✓</span>';
      nav.appendChild(b); navLinks[m.id]=b;
      if(m.subs&&m.subs.length){
        var sn=document.createElement("div"); sn.className="subnav";
        m.subs.forEach(function(s){
          var a=document.createElement("a"); a.href="#"+m.id+"::"+s[0]; a.textContent=s[1];
          a.dataset.go=m.id; a.dataset.anchor=s[0]; sn.appendChild(a);
        });
        nav.appendChild(sn);
      }
